{
  "name": "@aurelienbbn/harness",
  "version": "0.0.0",
  "private": true,
  "description": "Shared quality tooling for Aurelien projects.",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run build && npm run lint && npm run fmt:check && npm test",
    "lint": "oxlint",
    "fmt": "oxfmt --write",
    "fmt:check": "oxfmt --check",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "npm@11.13.0"
}
