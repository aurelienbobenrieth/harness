{
  "name": "@aurelienbbn/harness",
  "version": "0.0.0",
  "private": true,
  "description": "Shared quality tooling for Aurelien projects.",
  "type": "module",
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run build && npm run lint",
    "lint": "oxlint",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3"
  }
}
