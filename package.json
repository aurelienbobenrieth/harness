{
  "name": "@aurelienbbn/harness",
  "version": "0.0.0",
  "private": true,
  "description": "Shared quality tooling for Aurelien projects.",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm --recursive --if-present build",
    "check": "pnpm build && pnpm lint && pnpm fmt:check && pnpm test",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "test": "pnpm --recursive --if-present test",
    "test:watch": "pnpm --recursive --if-present test:watch",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "latest",
    "@voidzero-dev/vite-plus-core": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "tsdown": "latest",
    "typescript": "latest",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@11.9.0"
}
